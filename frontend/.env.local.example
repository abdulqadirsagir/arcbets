# ⚠️ DO NOT CREATE A .env.local FILE!
# All contract addresses are hardcoded in frontend/lib/contracts.ts
# Creating a .env.local will override the correct addresses and cause issues!

# If you need to change addresses, edit frontend/lib/contracts.ts directly

# Arc Network (these are already set in the code)
# NEXT_PUBLIC_CHAIN_ID=5042002
# NEXT_PUBLIC_RPC_URL=https://rpc.testnet.arc.network

# Contract Addresses (DO NOT SET - hardcoded in contracts.ts):
# NEXT_PUBLIC_ARCS_TOKEN_ADDRESS=0x7f326a2c29B8dF38E162AC99E63Bfa3d8860aF4e
# NEXT_PUBLIC_DEPOSIT_VAULT_ADDRESS=0x1412DA1926A1831D53B77Be8C841DAcf7C7E646C
# NEXT_PUBLIC_BETTING_ENGINE_ADDRESS=0x3E2D445b11D988Ac411a324a6b73A9A925f5D1AC
# NEXT_PUBLIC_ORACLE_ADDRESS=0xa97B0b72234EF7aE9934D836581B4771fc3D3247

# Supabase (optional, only if using Supabase)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
